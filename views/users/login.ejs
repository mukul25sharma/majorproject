<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <h1 class="col-6 offset-3">Login</h1>
  <div class="col-8 offset-3">
    <form action="/login" method="post">
      <div class="mb-3">
        <!-- mb3 bootsrap class for margin botton val 3-->
        <label for="username" class="form-label is-valid">username</label>
        <input
          name="username"
          id="username"
          type="text"
          class="form-control"
          required
        />
      </div>

      
        <!-- mb3 bootsrap class for margin botton val 3-->
        <label for="password" class="form-label is-valid">password</label>
        <input
          name="password"
          id="password"
          type="password"
          class="form-control"
          required
        />
      </div>

      <button class="btn btn-success col-1 offset-3 mt-2">Login</button>
    </form>
  </div>
</div>
